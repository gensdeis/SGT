# 숏게타 게임 서버 — 로컬 개발용 환경변수 예시
# 사용: cp .env.example .env.local && source .env.local && go run ./cmd/api

# === HTTP ===
PORT=8080
LOG_LEVEL=info

# === DB (docker-compose 기본값) ===
DATABASE_URL=postgres://shortgeta:devpass@localhost:5432/shortgeta_dev?sslmode=disable
DB_MAX_CONNS=10
DB_MIN_CONNS=2

# === Redis ===
REDIS_URL=redis://localhost:6379/0

# === JWT ===
JWT_SECRET=local-dev-jwt-secret-change-me
JWT_TTL_HOURS=720

# === HMAC anti-cheat ===
HMAC_BASE_KEY=local-dev-hmac-base-key
BUILD_GUID=local-dev-build-guid
HMAC_REPLAY_WINDOW_SEC=30

# === Mock 모드 (로컬 개발 전용) ===
DEV_MOCK_RECEIPT=true

# === 게임 메타 ===
GAMES_CONFIG_PATH=./config/games.yaml
