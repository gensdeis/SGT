<?xml version="1.0" encoding="utf-8"?>
<!--
  App-level Android manifest override (Unity 가 자동 머지).
  본 파일은 권한만 추가. HighlightRecording 네이티브 plugin 이 AAR 로
  정식 빌드되면 FileProvider / RecordingService / RecordingPermissionActivity
  엔트리를 복구할 예정 (native-android-src/HighlightRecording 참조).
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- dev 한정: HTTP 평문 허용 (local PC 서버 접근). 운영은 HTTPS 로 전환 후 제거. -->
    <application android:usesCleartextTraffic="true" />
</manifest>
