<?xml version="1.0" encoding="utf-8"?>
<!--
  App-level Android manifest override (Unity 가 자동 머지).
  본 파일은 권한 + foreground service type 만 추가. UnityPlayerActivity 등 base 는
  Unity 가 자동 생성하는 manifest 에서 처리.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.shortgeta.app">

    <!-- 화면 캡처 / foreground service 권한 -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION" />
    <!-- (선택) 음성 캡처 — 현재는 비활성 -->
    <!-- <uses-permission android:name="android.permission.RECORD_AUDIO" /> -->

    <application>
        <!--
          Iter 2B''' 에서 RecordingService 추가 예정:
          <service
              android:name="com.shortgeta.recording.RecordingService"
              android:foregroundServiceType="mediaProjection"
              android:exported="false" />
        -->
    </application>
</manifest>
